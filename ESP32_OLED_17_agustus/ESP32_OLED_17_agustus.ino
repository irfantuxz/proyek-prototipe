            else
              display.drawBitmap(47, 1, flag2_32px, 32, 32, WHITE);
            display.drawLine(2, 35, 125, 35, SSD1306_WHITE);
            display.setFont(&CalibriBold8pt);
            printCenter(timestring, 0, 38);
            printCenter(datestring, 0, 48);

        }
      }

      display.display();
    }
  }
