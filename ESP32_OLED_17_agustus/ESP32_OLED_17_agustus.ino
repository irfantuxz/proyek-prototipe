#define countof(a) (sizeof(a) / sizeof(a[0]))
void printDateTime(const RtcDateTime& dt) {
  char datestring[26];
  snprintf_P(datestring,
             countof(datestring),
             PSTR("%02u-%02u-%04u %02u:%02u:%02u"),
             dt.Day(),
             dt.Month(),
             dt.Year(),
             dt.Hour(),
             dt.Minute(),
             dt.Second());
  Serial.println(datestring);
}

void printCenter(const String buf, int x, int y) {
  int16_t x1, y1;
  uint16_t w, h;
  display.getTextBounds(buf, x, y, &x1, &y1, &w, &h);
  display.setCursor((x - w / 2) + (128 / 2), y + h);
  display.print(buf);
}

void setup() {
  // Inisiasi serial com
  Serial.begin(115200);
  while (!Serial) { ; }
  Serial.flush();

  // inisiasi pin output:
  // pinMode(Display_pin, OUTPUT);
  // pinMode(LED_pin, OUTPUT);
  // pinMode(MP3_GND_pin, OUTPUT);
  // pinMode(MP3_PWR_pin, OUTPUT);
  // pinMode(MP3_play_pin, OUTPUT);
  // pinMode(btnPWR, OUTPUT);
  // pinMode(btnINP, INPUT);
  pinMode(MP3_POWER, OUTPUT);

  // SSD1306_SWITCHCAPVCC = generate display voltage from 3.3V internally
  if (!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("SSD1306 allocation failed"));
  } else {
    beginDisplay = true;
    display.flush();
    display.clearDisplay();
    display.setTextColor(SSD1306_WHITE);
    display.setTextSize(1);
    display.setFont(&CalibriBold8pt);
    printCenter("- TuxZ -", 0, 28);
    display.display();
  }

  // inisiasi status pin
  // digitalWrite(Display_pin, beginDisplay);
  // digitalWrite(LED_pin, LOW);
  // digitalWrite(MP3_GND_pin, LOW);
  // digitalWrite(MP3_PWR_pin, LOW);
  // digitalWrite(MP3_play_pin, HIGH);
  // digitalWrite(btnPWR, LOW);
  // digitalWrite(btnINP, HIGH);

  // waktu
  Rtc.Begin();

  RtcDateTime compiled = RtcDateTime("Aug 17 2024","09:59:55");
  printDateTime(compiled);

  if (!Rtc.IsDateTimeValid()) {
    // Common Causes:
    //    1) first time you ran and the device wasn't running yet
    //    2) the battery on the device is low or even missing
    Serial.println(F("RTC tidak valid!"));
    Rtc.SetDateTime(compiled);
  }

  if (Rtc.GetIsWriteProtected()) {
    Serial.println(F("RTC write protected, enabling.."));
    Rtc.SetIsWriteProtected(false);
  }

  if (!Rtc.GetIsRunning()) {
    Serial.println(F("RTC not running, starting.."));
    Rtc.SetIsRunning(true);
  }

  RtcDateTime now = Rtc.GetDateTime();
  if (now < compiled) {
    Serial.println(F("RTC is older! Updating.."));
    Rtc.SetDateTime(compiled);
  } else if (now > compiled) {
    Serial.println(F("RTC is newer. OK"));
  } else if (now == compiled) {
    Serial.println(F("RTC is same. OK"));
  }
    Rtc.SetDateTime(compiled);
}

